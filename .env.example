# Server
PORT=3001
NODE_ENV=development          # development | production
CLIENT_ORIGIN=http://localhost:5173   # frontend CORS origin (dev only)

# Neon PostgreSQL — get this from your Neon project dashboard
# Format: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Client (Vite exposes VITE_* vars to the browser bundle)
VITE_APP_NAME=Showcase Nigeria
VITE_API_BASE=/api
